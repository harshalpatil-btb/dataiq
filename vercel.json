{
  "crons": [
    {
      "path": "/api/cron/trial-nudges",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/stall-detection",
      "schedule": "0 */6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/room/:slug",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
